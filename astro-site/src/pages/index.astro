---
import { getCollection } from "astro:content";
import SuperpowerNav from "../components/SuperpowerNav.astro";
import Footer from "../components/Footer.astro";
import SeoHead from "../components/SeoHead.astro";
import "../styles/global.css";

const posts = await getCollection("posts");
const recentPosts = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead
      title="K-PAI | Silicon Valley Privacy-Preserving AI Forum"
      description="Join K-PAI, the premier community for privacy-preserving AI research and development in Silicon Valley. Advancing AI ethics, security, and innovation."
      canonical={canonicalURL.toString()}
    />
  </head>
  <body class="bg-white">
    <!-- Navigation Component (outside of sticky container for proper z-index) -->
    <SuperpowerNav isHeroPage={true} />

    <!-- Hero Section with Video Background -->
    <div class="hero-scroll-container" id="hero-scroll-container">
      <section class="hero-section hero-sticky" id="hero-section">
        <!-- Background Video -->
        <div class="hero-video-container" id="hero-video-container">
          <video
            autoplay
            muted
            loop
            playsinline
            class="hero-video"
            id="hero-video"
          >
            <source src="/assets/images/video/landing_page.mp4" type="video/mp4" />
          </video>
          <div class="hero-video-overlay" id="hero-video-overlay"></div>
        </div>

        <div class="grid-pattern"></div>

        <!-- Hero Content (will fade on scroll) -->
        <div class="relative z-10 text-center px-4 max-w-5xl mx-auto hero-content" id="hero-content">
          <div class="fade-in-up visible">
            <span class="badge mb-6">Silicon Valley Community</span>
          </div>

          <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight fade-in-up visible delay-100">
            Privacy-Preserving
            <span class="text-gradient block mt-2">AI Forum</span>
          </h1>

          <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-10 fade-in-up visible delay-200">
            Advancing the future of AI with privacy, security, and ethics at the core.
            Join the leading community of researchers and engineers in Silicon Valley.
          </p>

          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 fade-in-up visible delay-300">
            <a href="https://lu.ma/kpai" target="_blank" rel="noopener noreferrer" class="btn-primary">
              RSVP on Luma
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a href="/about/" class="btn-secondary">
              Learn More
            </a>
          </div>

        </div>
      </section>
    </div>

    <!-- Hero Scroll Interaction Script -->
    <script>
      const heroScrollContainer = document.getElementById('hero-scroll-container');
      const heroSection = document.getElementById('hero-section');
      const heroContent = document.getElementById('hero-content');
      const heroVideoContainer = document.getElementById('hero-video-container');
      const heroVideoOverlay = document.getElementById('hero-video-overlay');

      // Scroll distance for video shrink animation (in pixels)
      const SHRINK_SCROLL_DISTANCE = 300;

      function handleHeroScroll() {
        const scrollY = window.scrollY;

        // Phase 1: Video shrinking (0 to SHRINK_SCROLL_DISTANCE)
        const shrinkProgress = Math.min(scrollY / SHRINK_SCROLL_DISTANCE, 1);

        if (heroContent) {
          // Fade out content
          heroContent.style.opacity = String(1 - shrinkProgress);
          heroContent.style.transform = `translateY(${-shrinkProgress * 30}px)`;
        }

        if (heroVideoContainer) {
          // Scale down subtly (100% to 95%)
          const scale = 1 - (shrinkProgress * 0.05);
          const borderRadius = shrinkProgress * 24;
          const inset = shrinkProgress * 16;
          heroVideoContainer.style.transform = `scale(${scale})`;
          heroVideoContainer.style.borderRadius = `${borderRadius}px`;
          heroVideoContainer.style.top = `${inset}px`;
          heroVideoContainer.style.left = `${inset}px`;
          heroVideoContainer.style.right = `${inset}px`;
          heroVideoContainer.style.bottom = `${inset}px`;
        }

        if (heroVideoOverlay) {
          const overlayOpacity = 0.6 - (shrinkProgress * 0.3);
          heroVideoOverlay.style.background = `rgba(15, 15, 26, ${overlayOpacity})`;
        }
      }

      window.addEventListener('scroll', handleHeroScroll);
      handleHeroScroll();
    </script>

    <!-- Partners Section -->
    <section class="py-8 bg-white border-b">
      <div class="container mx-auto px-4">
        <div class="flex flex-wrap items-center justify-center gap-10 md:gap-16">
          <a href="https://www.connectkotrasv.org/" target="_blank" rel="noopener noreferrer" class="flex-shrink-0">
            <img src="/resource/org-logos/kotra-silicon-valley-logo.jpeg" alt="KOTRA Silicon Valley" class="h-10 w-auto grayscale hover:grayscale-0 transition-all" />
          </a>
          <a href="https://kbiox.net/" target="_blank" rel="noopener noreferrer" class="flex-shrink-0">
            <img src="/resource/org-logos/k-biox-logo-02.png" alt="K-BioX" class="h-10 w-auto grayscale hover:grayscale-0 transition-all" />
          </a>
          <a href="https://overseas.mofa.go.kr/us-sanfrancisco-ko/index.do" target="_blank" rel="noopener noreferrer" class="flex-shrink-0">
            <img src="/resource/org-logos/korean-consulate-general-san-francisco-logo.png" alt="Consulate General of Republic of Korea" class="h-10 w-auto grayscale hover:grayscale-0 transition-all" />
          </a>
          <a href="https://www.kabanc.com/" target="_blank" rel="noopener noreferrer" class="flex-shrink-0">
            <img src="/resource/org-logos/kabanc-logo-01.jpeg" alt="KABANC" class="h-10 w-auto grayscale hover:grayscale-0 transition-all" />
