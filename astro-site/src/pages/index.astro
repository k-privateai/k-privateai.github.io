          </div>

          <!-- Video Podcast 2 -->
          <div class="rounded-2xl overflow-hidden border border-gray-200 bg-white fade-in-up delay-100">
            <div class="bg-[var(--color-dark)] text-white p-4">
              <h3 class="font-semibold text-sm">K-PAI - AI & Privacy</h3>
              <span class="text-xs text-gray-400">(06:14)</span>
            </div>
