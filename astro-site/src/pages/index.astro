              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>

          <!-- Event 2 -->
          <div class="p-6 rounded-2xl border border-gray-200 bg-white fade-in-up delay-100">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Edge Intelligence - Privacy-Preserving AI at the Network Periphery</h3>
            <div class="text-sm text-gray-600 space-y-1">
              <p class="flex items-center gap-1.5">
