---

<BaseLayout title="Events | K-PAI" description="K-PAI Forum events calendar - upcoming and past events in privacy-preserving AI">
  <div class="max-w-6xl mx-auto px-4 lg:px-8">
    <!-- Page Header -->
    <div class="text-center mb-16">
      <span class="badge mb-4">Calendar</span>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">K-PAI Events</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Monthly forums bringing together the brightest minds in privacy-preserving AI.
        Join us for seminars, workshops, and community events.
      </p>
    </div>

    <!-- Upcoming Events 2026 -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <span class="badge">2026</span>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900">Upcoming Events</h2>
      </div>

      <div class="space-y-4">
        {upcomingEvents2026.map((event) => (
          <div class={`relative p-6 rounded-2xl border transition-all hover:shadow-lg ${event.highlight ? 'border-[var(--color-primary)] bg-purple-50/50' : event.isSpecial ? 'border-amber-300 bg-amber-50/50' : 'border-gray-200 bg-white'}`}>
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
              <div class="flex-1">
                {event.highlight && <span class="inline-block px-2 py-0.5 text-xs font-semibold bg-[var(--color-primary)] text-white rounded-full mb-2">Next Event</span>}
                {event.isSpecial && <span class="inline-block px-2 py-0.5 text-xs font-semibold bg-amber-500 text-white rounded-full mb-2">Special Event</span>}
                <h3 class="text-lg font-bold text-gray-900">{event.title}</h3>
                <div class="flex flex-wrap items-center gap-4 mt-2 text-sm text-gray-600">
                  <span class="flex items-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                    {event.date}
                  </span>
                  {event.venueUrl ? (
                    <a href={event.venueUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-[var(--color-primary)] hover:underline">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                      {event.venue}
                    </a>
                  ) : (
                    <span class="flex items-center gap-1.5">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                      {event.venue}
                    </span>
                  )}
                </div>
                {event.note && <p class="mt-2 text-sm text-[var(--color-primary)] font-medium">{event.note}</p>}
              </div>
              {event.rsvp && (
                <a href={event.rsvp} target="_blank" rel="noopener noreferrer" class="btn-primary text-sm !py-2.5 !px-5 whitespace-nowrap">
                  RSVP on Luma
                  <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- 2027 Preview -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <span class="badge">2027</span>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900">2027 Forums Preview</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        {upcomingEvents2027.map((event) => (
          <div class={`p-5 rounded-xl border transition-all hover:shadow-md ${event.isSpecial ? 'border-amber-300 bg-amber-50/50' : 'border-gray-200 bg-white'}`}>
            {event.isSpecial && <span class="inline-block px-2 py-0.5 text-xs font-semibold bg-amber-500 text-white rounded-full mb-2">Special Event</span>}
            <h3 class="text-base font-bold text-gray-900 mb-2">{event.title}</h3>
            <p class="text-sm text-gray-500 mb-1">{event.date}</p>
            {event.theme && <p class="text-xs text-[var(--color-primary)] font-medium">{event.theme}</p>}
          </div>
        ))}
      </div>
    </section>

    <!-- Past Events -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <span class="badge">Archive</span>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900">Past Events</h2>
      </div>

      <div class="space-y-3">
        {pastEvents.map((event) => (
          <div class="p-5 rounded-xl border border-gray-200 bg-white hover:shadow-md transition-all">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3">
              <div class="flex-1">
                <h3 class="text-base font-bold text-gray-900">{event.title}</h3>
                <div class="flex flex-wrap items-center gap-3 mt-1.5 text-sm text-gray-500">
                  <span>{event.date}</span>
                  <span class="text-gray-300">|</span>
                  <span>{event.venue}</span>
                </div>
                {event.speakers && event.speakers.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-1.5">
                    {event.speakers.map((speaker) => (
                      <span class="inline-block px-2 py-0.5 text-xs bg-gray-100 text-gray-600 rounded-full">{speaker}</span>
                    ))}
                  </div>
                )}
                {event.note && <p class="mt-1.5 text-sm text-[var(--color-primary)] font-medium">{event.note}</p>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="text-center py-16 mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Don't Miss the Next Forum</h2>
      <p class="text-gray-600 mb-8 max-w-xl mx-auto">
        RSVP on Luma to receive updates and secure your spot at upcoming K-PAI events.
      </p>
      <a href="https://lu.ma/kpai" target="_blank" rel="noopener noreferrer" class="btn-primary">
        RSVP on Luma
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </section>
  </div>
</BaseLayout>
